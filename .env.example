# Investment App configuration. Copy to .env and fill in values.
# setup.sh will auto-generate APP_ENCRYPTION_KEY and JWT_SECRET if you let it.

# --- Auto-generated secrets (run setup.sh to populate) ---
APP_ENCRYPTION_KEY=
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# --- AI chatbot (per-user keys are also supported via Settings page) ---
# Optional global fallback. If unset, users must add their own key in Settings.
ANTHROPIC_API_KEY=
# Override the Claude model without code changes (e.g. for testing newer releases).
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Required market-data API keys (app refuses to start without these) ---
# Free tier: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
# Free tier: https://openexchangerates.org/signup/free
OPEN_EXCHANGE_RATES_KEY=
# Free tier: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_KEY=

# --- Database ---
DATABASE_URL=sqlite:///./app.db

# --- CORS allowed origins (comma-separated). Leave empty to fall back to
# the bundled localhost + Render defaults. For a different prod domain,
# add it here explicitly — wildcard "*" with credentials is invalid per
# the CORS spec and browsers will silently ignore the credentials. ---
CORS_ALLOWED_ORIGINS=

# --- Sentry error reporting (optional). Paste DSN from sentry.io. Empty
# disables the SDK (no-op import). 5% trace sample fits the free tier. ---
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.05

# --- PostHog product analytics (optional). Free tier ~1M events/mo.
# Use eu.i.posthog.com if your project is in the EU region. ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
