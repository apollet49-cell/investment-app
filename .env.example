# Investment App configuration. Copy to .env and fill in values.
# setup.sh will auto-generate APP_ENCRYPTION_KEY and JWT_SECRET if you let it.

# --- Auto-generated secrets (run setup.sh to populate) ---
APP_ENCRYPTION_KEY=
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# --- AI chatbot (per-user keys are also supported via Settings page) ---
# Optional global fallback. If unset, users must add their own key in Settings.
ANTHROPIC_API_KEY=

# --- Required market-data API keys (app refuses to start without these) ---
# Free tier: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=
# Free tier: https://openexchangerates.org/signup/free
OPEN_EXCHANGE_RATES_KEY=
# Free tier: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_KEY=

# --- Database ---
DATABASE_URL=sqlite:///./app.db
